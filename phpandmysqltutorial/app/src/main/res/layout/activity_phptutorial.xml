<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backcolor"
    android:contentDescription="@string/app_name"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    tools:ignore="ScrollViewCount">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp">


        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4facfe"
            android:minHeight="?attr/actionBarSize"
            android:textAlignment="center"
            android:theme="?attr/actionBarTheme">

            <ImageButton
                android:id="@+id/imageButton3"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start"
                android:background="#4facfe"
                android:contentDescription="@string/app_name"
                android:minHeight="48dp"
                app:srcCompat="@drawable/ic_back_24" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:text="   PHP TUTORIAL"
                android:textColor="#1E1D1D"
                android:textSize="28dp"
                android:textStyle="bold" />


        </androidx.appcompat.widget.Toolbar>

        <Button
            android:id="@+id/button31"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="php introduction"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_1_24"
            app:iconTint="@color/black" />


        <Button
            android:id="@+id/button32"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="syntax,comments"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_2_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button33"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="variables,data types"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_3_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button34"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="strings"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_4_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button35"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="constants,operators"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_5_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button36"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="CONDITIONS AND LOOPS"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_6_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button37"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="form handling"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_7_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button38"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="file handling"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_8_24"
            app:iconTint="@color/black" />

        <Button
            android:id="@+id/button39"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/amarante"
            android:text="sessions and cookies"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_baseline_filter_9_24"
            app:iconTint="@color/black" />

    </LinearLayout>


</ScrollView>